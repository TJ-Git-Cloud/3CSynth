<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSExtension</key>
    <dict>
        <key>NSExtensionPointIdentifier</key>
        <string>com.apple.AudioUnit-UI</string>

        <key>NSExtensionPrincipalClass</key>
        <string>$(PRODUCT_MODULE_NAME).ThreeCSynthMacAUViewController</string>

        <!-- AudioComponents MUST live inside NSExtensionAttributes for CoreAudio
             to discover and register the plug-in component. -->
        <key>NSExtensionAttributes</key>
        <dict>
            <key>AudioComponents</key>
            <array>
                <dict>
                    <key>type</key>
                    <string>aumu</string>

                    <key>subtype</key>
                    <string>3CSy</string>

                    <key>manufacturer</key>
                    <string>3CSA</string>

                    <key>name</key>
                    <string>3CSynth Audio: 3CSynth</string>

                    <key>description</key>
                    <string>Hybrid subtractive/wavetable synthesizer</string>

                    <key>version</key>
                    <integer>65536</integer>

                    <!-- factoryFunction must match the Swift class name without module prefix -->
                    <key>factoryFunction</key>
                    <string>$(PRODUCT_MODULE_NAME).ThreeCSynthMacAUViewController</string>

                    <key>sandboxSafe</key>
                    <true/>
                </dict>
            </array>
        </dict>
    </dict>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>

    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 3CSynth Audio. All rights reserved.</string>
</dict>
</plist>
