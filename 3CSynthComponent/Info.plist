<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>

    <key>CFBundlePackageType</key>
    <string>BNDL</string>

    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>

    <!-- NSPrincipalClass and factoryFunction both point to the AUAudioUnit subclass.
         CoreAudio uses NSClassFromString(factoryFunction) to instantiate the AU. -->
    <key>NSPrincipalClass</key>
    <string>ThreeCSynthComponentAU</string>

    <key>AudioComponents</key>
    <array>
        <dict>
            <key>type</key>
            <string>aumu</string>

            <key>subtype</key>
            <string>3CSy</string>

            <key>manufacturer</key>
            <string>3CSA</string>

            <key>name</key>
            <string>3CSynth Audio: 3CSynth</string>

            <key>description</key>
            <string>Hybrid subtractive/wavetable synthesizer</string>

            <key>version</key>
            <integer>65536</integer>

            <!-- Must match the @objc class name exported from the bundle. -->
            <key>factoryFunction</key>
            <string>ThreeCSynthComponentAU</string>

            <!-- sandboxSafe lets Logic load the component in-process on macOS 13+. -->
            <key>sandboxSafe</key>
            <true/>
        </dict>
    </array>

    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 3CSynth Audio. All rights reserved.</string>
</dict>
</plist>
